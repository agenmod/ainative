# 认证模块 — 复制为 .env 后填写本地值（勿将真实 .env 提交仓库）
# 说明见 auth_module/README.md 与 AUTH_INTEGRATION.md

# 必选：PostgreSQL
DATABASE_URL=postgresql://user:change-me@localhost:5432/myapp

# 可选：Redis（限流、忘记密码 token；留空则相关功能降级）
REDIS_URL=

# 可选：JWT（配置后登录返回 access_token）
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 可选：SMTP（忘记密码邮件）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ExampleApp
SMTP_USE_TLS=true

# 站点根 URL（用于重置密码链接）
SITE_URL=https://example.com
