# 用量模块 — 复制为 .env 后填写本地值（勿将真实 .env 提交仓库）
# 变量前缀为 USAGE_，说明见 usage_module/README.md 与 USAGE_INTEGRATION.md

# 必选：与接入方使用同一 PostgreSQL 时填相同连接串
USAGE_DATABASE_URL=postgresql://user:change-me@localhost:5432/myapp

# 可选：默认每用户 token 额度
USAGE_DEFAULT_TOKEN_LIMIT=500000

# 可选：表名（与默认一致时可省略）
# USAGE_TABLE_USER_LLM_USAGE=user_llm_usage
# USAGE_TABLE_USAGE_RECORDS=usage_records

# 可选：是否写入用量明细表
USAGE_ENABLE_USAGE_RECORDS=false

# 可选：若用量字段在接入方 User 表上，填写列名；留空则使用 user_llm_usage 表
# USAGE_USER_TABLE_TOKENS_USED_COLUMN=
# USAGE_USER_TABLE_TOKENS_LIMIT_COLUMN=
